{
  "name": "UnblockFlix",
  "version": "1.0",
  "manifest_version": 3,
  "description": "Fixes Netflix playback issues and removes blocking elements for smooth streaming.",

  "permissions": [
    "webRequest",
    "webRequestBlocking"
  ],

  "host_permissions": [
    "*://www.netflix.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://www.netflix.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}